ANTHROPIC_API_KEY=your_api_key_here
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
LOG_LEVEL=INFO
DEMO_MODE=true
FALLBACK_ENABLED=true
PIPELINE_TIMEOUT_SECONDS=300

# Frontend API base URL:
# - Docker (default): leave empty — Nginx proxies /api/* to backend
# - Local dev (no Docker): set to http://localhost:8000/api
VITE_API_BASE_URL=
