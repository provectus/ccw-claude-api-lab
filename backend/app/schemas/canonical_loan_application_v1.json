{
  "schema_version": "1.0",
  "name": "canonical_loan_application",
  "description": "Canonical structure for a commercial loan application package. parse_loan_package normalizes raw borrower files into this shape; all downstream tools consume it.",
  "type": "object",
  "required": [
    "borrower_id",
    "business_name",
    "industry_naics",
    "requested_amount",
    "requested_term_months",
    "purpose",
    "financials"
  ],
  "properties": {
    "borrower_id": {
      "type": "string",
      "description": "Unique borrower identifier."
    },
    "business_name": {
      "type": "string",
      "description": "Legal name of the borrowing entity."
    },
    "industry_naics": {
      "type": "string",
      "description": "6-digit NAICS industry classification code.",
      "pattern": "^[0-9]{6}$"
    },
    "requested_amount": {
      "type": "number",
      "description": "Requested loan principal in USD."
    },
    "requested_term_months": {
      "type": "integer",
      "description": "Requested amortization term in months."
    },
    "purpose": {
      "type": "string",
      "description": "Stated use of proceeds (e.g. equipment, working_capital, real_estate, expansion, refinance)."
    },
    "financials": {
      "type": "array",
      "description": "Yearly financial statements, ordered oldest to newest. Three years expected.",
      "items": {
        "type": "object",
        "required": [
          "fiscal_year",
          "revenue",
          "cogs",
          "opex",
          "ebitda",
          "net_income",
          "total_assets",
          "total_liabilities",
          "equity",
          "cash",
          "accounts_receivable",
          "inventory",
          "current_assets",
          "current_liabilities"
        ],
        "properties": {
          "fiscal_year": {"type": "integer", "description": "Calendar/fiscal year of the statement."},
          "revenue": {"type": "number", "description": "Total revenue / net sales."},
          "cogs": {"type": "number", "description": "Cost of goods sold."},
          "opex": {"type": "number", "description": "Operating expenses excluding COGS."},
          "ebitda": {"type": "number", "description": "Earnings before interest, taxes, depreciation, amortization."},
          "net_income": {"type": "number", "description": "Bottom-line net income."},
          "total_assets": {"type": "number", "description": "Total assets."},
          "total_liabilities": {"type": "number", "description": "Total liabilities."},
          "equity": {"type": "number", "description": "Total shareholders' equity."},
          "cash": {"type": "number", "description": "Cash and cash equivalents."},
          "accounts_receivable": {"type": "number", "description": "Accounts receivable."},
          "inventory": {"type": "number", "description": "Inventory at cost."},
          "current_assets": {"type": "number", "description": "Total current assets."},
          "current_liabilities": {"type": "number", "description": "Total current liabilities."}
        }
      }
    },
    "collateral": {
      "type": "object",
      "description": "Optional pledged collateral.",
      "properties": {
        "type": {"type": "string", "description": "Collateral type (e.g. commercial_real_estate, equipment, receivables)."},
        "appraised_value": {"type": "number", "description": "Most recent appraised value in USD."}
      }
    }
  }
}
